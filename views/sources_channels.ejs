<%- include('partials/header', { title: t('channels.titleSource', { name: source.name }) + ' - ' + t('app.name') }) %>
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0"><i class="bi bi-list-ul"></i>
      <%= t('channels.channelsOf') %> <span class="text-primary"><%= source.name %></span>
    </h4>
    <a href="/sources" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i>
      <%= t('common.back') %></a>
  </div>

  <div class="alert alert-info py-2">
    <i class="bi bi-info-circle"></i> <%= t('channels.infoSource') %>
  </div>

  <form method="get" class="row g-2 mb-3" data-no-loading="1">
    <div class="input-group">
      <span class="input-group-text"><i class="bi bi-search"></i></span>
      <input type="text" name="q" value="<%= q %>" class="form-control"
        placeholder="<%= t('channels.searchPlaceholder') %>">
      <button class="btn btn-primary"><%= t('common.search') %></button>
      <% if (q) { %>
        <a href="/sources/<%= source.id %>/channels" class="btn btn-outline-secondary">
          <%= t('common.clear') %>
        </a>
      <% } %>
    </div>
  </form>

  <div class="text-center">
    <span class="text-secondary">
      <%= total.toLocaleString(lang) %> <%= t('common.results') %> ·
      <%= t('common.page') %> <%= page %> <%= t('common.pageOf') %> <%= totalPages %> ·
      <%= perPage %> <%= t('common.perPage') %>
    </span>
  </div>

  <%- include('partials/pagination', { page, totalPages, q, extraParams: {}, navClass: 'mt-3' }) %>

  <div class="table-responsive mt-2">
    <table class="table table-dark table-striped align-middle">
      <thead>
        <tr>
          <th><%= t('channels.group') %></th>
          <th><%= t('channels.tvgName') %></th>
          <th><%= t('channels.displayName') %></th>
          <th><%= t('channels.tvgId') %></th>
          <th><%= t('common.url') %></th>
        </tr>
      </thead>
      <tbody>
        <% channels.forEach(c => { %>
          <tr>
            <td><%= c.group_title || t('common.none_dash') %></td>
            <td><%= c.tvg_name || t('common.none_dash') %></td>
            <td><%= c.display_name || t('common.none_dash') %></td>
            <td class="text-secondary"><%= c.tvg_id || t('common.none_dash') %></td>
            <td>
              <input type="text" class="form-control app-url-cell js-copy-url" readonly
                spellcheck="false" value="<%= c.url %>">
            </td>
          </tr>
        <% }) %>
        <% if (channels.length === 0) { %>
          <tr>
            <td colspan="5" class="text-secondary text-center py-3">
              <%= q ? t('channels.none') : t('channels.noneSync') %>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <%- include('partials/pagination', { page, totalPages, q, extraParams: {}, navClass: 'mt-3' }) %>
  <%- include('partials/footer') %>
