<% if (totalPages> 1) {
  const qs = (p) => {
  const u = new URLSearchParams();
  if (q) u.set('q', q);
  Object.keys(extraParams || {}).forEach(k => { if (extraParams[k]) u.set(k, extraParams[k]); });
  u.set('page', p);
  return u.toString();
  };
  const win = 2;
  const start = Math.max(1, page - win);
  const end = Math.min(totalPages, page + win);
  %>
  <nav class="<%= navClass || 'mt-3' %>">
    <ul class="pagination justify-content-center flex-wrap mb-0">
      <li class="page-item <%= page === 1 ? 'disabled' : '' %>"><a class="page-link" href="?<%= qs(1) %>">«</a></li>
      <li class="page-item <%= page === 1 ? 'disabled' : '' %>"><a class="page-link"
          href="?<%= qs(Math.max(1, page - 1)) %>">‹</a></li>
      <% if (start> 1) { %><li class="page-item disabled"><span class="page-link">…</span></li>
        <% } %>
          <% for (let p=start; p <=end; p++) { %>
            <li class="page-item <%= p === page ? 'active' : '' %>"><a class="page-link" href="?<%= qs(p) %>">
                <%= p %>
              </a></li>
            <% } %>
              <% if (end < totalPages) { %>
                <li class="page-item disabled"><span class="page-link">…</span></li>
                <% } %>
                  <li class="page-item <%= page === totalPages ? 'disabled' : '' %>"><a class="page-link"
                      href="?<%= qs(Math.min(totalPages, page + 1)) %>">›</a></li>
                  <li class="page-item <%= page === totalPages ? 'disabled' : '' %>"><a class="page-link"
                      href="?<%= qs(totalPages) %>">»</a></li>
    </ul>
  </nav>
  <% } %>